from pydantic import BaseModel
from typing import Literal, List, Optional

class ProductCreate(BaseModel):
    name: str
    width: float
    height: float
    depth: float
    weight: float
    quantity: int
    security: str
    temperature: str

class ProductOut(ProductCreate):
    id: int
    class Config:
        orm_mode = True




